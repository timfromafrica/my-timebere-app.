<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes">
  <title>Supabase · personal data</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: system-ui, -apple-system, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    }

    body {
      background: #f8fafc;
      min-height: 100vh;
      display: flex;
      justify-content: center;
      align-items: center;
      padding: 20px 16px;
    }

    .app-card {
      max-width: 480px;
      width: 100%;
      background: white;
      border-radius: 32px;
      box-shadow: 0 12px 40px rgba(0, 0, 0, 0.06);
      padding: 28px 20px 32px;
      transition: all 0.2s;
    }

    h1 {
      font-size: 1.7rem;
      font-weight: 600;
      letter-spacing: -0.01em;
      color: #0b1e33;
      margin-bottom: 24px;
      padding-left: 4px;
      border-left: 5px solid #3b82f6;
      padding-left: 14px;
    }

    .input-group {
      display: flex;
      flex-direction: column;
      gap: 6px;
      margin-bottom: 22px;
      padding: 0 4px;
    }

    .input-group label {
      font-size: 0.9rem;
      font-weight: 500;
      color: #1e293b;
      letter-spacing: 0.01em;
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .input-group label span {
      color: #64748b;
      font-weight: 400;
      font-size: 0.75rem;
    }

    .input-group input,
    .input-group textarea {
      width: 100%;
      padding: 14px 16px;
      background: #f1f5f9;
      border: 1.5px solid #e2e8f0;
      border-radius: 18px;
      font-size: 1rem;
      transition: 0.2s;
      outline: none;
      color: #0f172a;
    }

    .input-group input:focus,
    .input-group textarea:focus {
      border-color: #3b82f6;
      background: #ffffff;
      box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.12);
    }

    .input-group textarea {
      min-height: 70px;
      resize: vertical;
    }

    .send-btn {
      width: 100%;
      background: #3b82f6;
      border: none;
      padding: 16px 20px;
      border-radius: 60px;
      font-size: 1.1rem;
      font-weight: 600;
      color: white;
      letter-spacing: 0.3px;
      margin: 10px 0 24px 0;
      box-shadow: 0 6px 14px rgba(59, 130, 246, 0.3);
      transition: 0.15s;
      cursor: pointer;
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 8px;
    }

    .send-btn:active {
      transform: scale(0.97);
      background: #2563eb;
      box-shadow: 0 3px 8px rgba(59, 130, 246, 0.3);
    }

    .send-btn:disabled {
      opacity: 0.6;
      transform: scale(0.98);
      box-shadow: none;
      pointer-events: none;
    }

    .divider {
      margin: 18px 0 20px 0;
      border: 0;
      height: 2px;
      background: linear-gradient(90deg, #e2e8f0, #b9c7da, #e2e8f0);
      border-radius: 4px;
    }

    .data-header {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      margin-bottom: 14px;
      padding: 0 2px;
    }

    .data-header h3 {
      font-size: 1.2rem;
      font-weight: 600;
      color: #0b1e33;
    }

    .data-header .count-badge {
      background: #e2e8f0;
      padding: 4px 14px;
      border-radius: 30px;
      font-size: 0.8rem;
      font-weight: 500;
      color: #1e293b;
    }

    .data-list {
      display: flex;
      flex-direction: column;
      gap: 18px;
      margin-top: 6px;
      max-height: 380px;
      overflow-y: auto;
      padding-right: 4px;
    }

    .data-item {
      background: #fafcff;
      border: 1px solid #eef2f6;
      border-radius: 24px;
      padding: 18px 18px 16px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.02);
      transition: 0.1s;
    }

    .data-item .row {
      display: flex;
      flex-wrap: wrap;
      align-items: baseline;
      gap: 6px 8px;
      margin-bottom: 6px;
    }

    .data-item .row:last-child {
      margin-bottom: 0;
    }

    .data-item .label {
      font-size: 0.7rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.03em;
      color: #64748b;
      min-width: 64px;
    }

    .data-item .value {
      font-size: 0.98rem;
      font-weight: 500;
      color: #0f172a;
      word-break: break-word;
      background: #f1f5f9;
      padding: 4px 12px;
      border-radius: 40px;
      display: inline-block;
      max-width: 100%;
    }

    .data-item .value.bio-value {
      background: transparent;
      padding: 4px 0;
      border-radius: 0;
      display: block;
      width: 100%;
      margin-top: 2px;
      font-weight: 400;
      color: #1e293b;
    }

    .empty-message {
      text-align: center;
      color: #94a3b8;
      font-size: 0.95rem;
      padding: 36px 10px 30px;
      background: #f8fafc;
      border-radius: 40px;
      border: 1px dashed #d1d9e6;
    }

    .spacer {
      height: 6px;
    }

    .data-list::-webkit-scrollbar {
      width: 4px;
    }
    .data-list::-webkit-scrollbar-track {
      background: #eef2f6;
      border-radius: 10px;
    }
    .data-list::-webkit-scrollbar-thumb {
      background: #b9c7da;
      border-radius: 10px;
    }

    .feedback {
      margin-top: -6px;
      margin-bottom: 14px;
      font-size: 0.85rem;
      font-weight: 500;
      padding-left: 6px;
      color: #2563eb;
    }
  </style>
</head>
<body>
  <div class="app-card" id="app">
    <h1>📋 my data</h1>

    <div class="input-group">
      <label>Full name <span>· required</span></label>
      <input type="text" id="fullName" placeholder="e.g. Alex Rivera" autocomplete="name">
    </div>

    <div class="input-group">
      <label>Email <span>· required</span></label>
      <input type="email" id="email" placeholder="alex@example.com" autocomplete="email">
    </div>

    <div class="input-group">
      <label>Age <span>· optional</span></label>
      <input type="number" id="age" placeholder="29" min="1" max="130">
    </div>

    <div class="input-group">
      <label>Country <span>· optional</span></label>
      <input type="text" id="country" placeholder="e.g. Canada">
    </div>

    <div class="input-group">
      <label>Bio / note <span>· optional</span></label>
      <textarea id="bio" placeholder="Tell something about yourself..."></textarea>
    </div>

    <button class="send-btn" id="sendBtn">✉️ Send</button>
    <div id="feedbackMessage" class="feedback"></div>

    <hr class="divider">

    <div class="data-header">
      <h3>📦 stored entries</h3>
      <span class="count-badge" id="countBadge">0</span>
    </div>

    <div id="dataContainer" class="data-list">
      <div class="empty-message">✨ no data yet · send your first entry</div>
    </div>

    <div class="spacer"></div>
  </div>

  <script>
    (function() {
      // ---------- YOUR SUPABASE CREDENTIALS (exactly as tested) ----------
      const SUPABASE_URL = 'https://dsnhvvonkoapooabsszt.supabase.co';
      const SUPABASE_ANON_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImRzbmh2dm9ua29hcG9vYWJzc3p0Iiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc4MzM2NDEyMSwiZXhwIjoyMDk4OTQwMTIxfQ.9pSlFeI0nNtRyX4gAVHYUeiRx5Vj2VPOLIdPWtMUWC8';

      // ---------- DOM refs ----------
      const fullNameInput = document.getElementById('fullName');
      const emailInput = document.getElementById('email');
      const ageInput = document.getElementById('age');
      const countryInput = document.getElementById('country');
      const bioInput = document.getElementById('bio');
      const sendBtn = document.getElementById('sendBtn');
      const feedbackEl = document.getElementById('feedbackMessage');
      const dataContainer = document.getElementById('dataContainer');
      const countBadge = document.getElementById('countBadge');

      // ---------- helpers ----------
      function showFeedback(msg, isError = false) {
        feedbackEl.textContent = msg;
        feedbackEl.style.color = isError ? '#b91c1c' : '#2563eb';
        if (!isError) {
          setTimeout(() => {
            if (feedbackEl.textContent === msg) feedbackEl.textContent = '';
          }, 5000);
        }
      }

      function escapeHtml(text) {
        if (typeof text !== 'string') return text;
        const map = { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#039;' };
        return text.replace(/[&<>"']/g, m => map[m]);
      }

      // ---------- fetch & render (plain fetch) ----------
      async function fetchAndRender() {
        try {
          const url = `${SUPABASE_URL}/rest/v1/profiles?order=created_at.desc`;
          const res = await fetch(url, {
            headers: {
              'apikey': SUPABASE_ANON_KEY,
              'Authorization': `Bearer ${SUPABASE_ANON_KEY}`
            }
          });
          if (!res.ok) {
            const text = await res.text();
            throw new Error(`HTTP ${res.status}: ${text}`);
          }
          const data = await res.json();
          renderData(data);
        } catch (err) {
          console.error('Fetch error:', err);
          showFeedback('⚠️ Could not load data: ' + err.message, true);
        }
      }

      function renderData(records) {
        if (!records || records.length === 0) {
          dataContainer.innerHTML = `<div class="empty-message">📭 no entries · send your first</div>`;
          countBadge.textContent = '0';
          return;
        }

        let html = '';
        records.forEach(record => {
          const fullName = record.full_name || '—';
          const email = record.email || '—';
          const age = record.age ?? '—';
          const country = record.country || '—';
          const bio = record.bio || '—';

          html += `
            <div class="data-item">
              <div class="row">
                <span class="label">name</span>
                <span class="value">${escapeHtml(fullName)}</span>
              </div>
              <div class="row">
                <span class="label">email</span>
                <span class="value">${escapeHtml(email)}</span>
              </div>
              <div class="row">
                <span class="label">age</span>
                <span class="value">${escapeHtml(String(age))}</span>
                <span class="label" style="margin-left:12px;">country</span>
                <span class="value">${escapeHtml(String(country))}</span>
              </div>
              <div class="row">
                <span class="label">bio</span>
                <span class="value bio-value">${escapeHtml(bio) || '—'}</span>
              </div>
            </div>
          `;
        });

        dataContainer.innerHTML = html;
        countBadge.textContent = records.length;
      }

      // ---------- send data (plain fetch POST) ----------
      async function sendData() {
        const fullName = fullNameInput.value.trim();
        const email = emailInput.value.trim();
        const ageRaw = ageInput.value.trim();
        const country = countryInput.value.trim();
        const bio = bioInput.value.trim();

        if (!fullName || !email) {
          showFeedback('⚠️ Full name and email are required.', true);
          return;
        }

        let age = null;
        if (ageRaw !== '') {
          const parsed = Number(ageRaw);
          if (!isNaN(parsed) && parsed > 0 && parsed < 130) {
            age = parsed;
          } else {
            showFeedback('⚠️ Please enter a valid age (1-130) or leave empty.', true);
            return;
          }
        }

        const payload = {
          full_name: fullName,
          email: email,
          age: age,
          country: country || null,
          bio: bio || null,
        };

        sendBtn.disabled = true;
        sendBtn.textContent = '⏳ sending...';

        try {
          const url = `${SUPABASE_URL}/rest/v1/profiles`;
          const res = await fetch(url, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'apikey': SUPABASE_ANON_KEY,
              'Authorization': `Bearer ${SUPABASE_ANON_KEY}`,
              'Prefer': 'return=representation'
            },
            body: JSON.stringify(payload)
          });

          if (!res.ok) {
            const text = await res.text();
            throw new Error(`HTTP ${res.status}: ${text}`);
          }

          showFeedback('✅ Data sent successfully!');
          // clear inputs
          fullNameInput.value = '';
          emailInput.value = '';
          ageInput.value = '';
          countryInput.value = '';
          bioInput.value = '';

          // refresh the list
          await fetchAndRender();
        } catch (err) {
          console.error('Insert error:', err);
          showFeedback('❌ Failed to send: ' + err.message, true);
        } finally {
          sendBtn.disabled = false;
          sendBtn.innerHTML = '✉️ Send';
        }
      }

      // ---------- initial load ----------
      async function init() {
        try {
          await fetchAndRender();
        } catch (e) {
          console.warn('Init fetch issue:', e);
          dataContainer.innerHTML = `<div class="empty-message">⚠️ could not connect to supabase</div>`;
        }
      }

      // ----- event listeners -----
      sendBtn.addEventListener('click', sendData);

      // start
      init();
    })();
  </script>
</body>
</html>
